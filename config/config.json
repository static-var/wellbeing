{
  "bind_addr": "127.0.0.1:8080",
  "database": {
    "path": "data/wellbeing.sqlite"
  },
  "checkins": {
    "tick_interval_secs": 60,
    "batch_size": 25,
    "recent_activity_grace_minutes": 360
  },
  "telegram": {
    "poll_interval_secs": 5,
    "api_base_url": "https://api.telegram.org"
  },
  "whisper": {
    "worker_url": "http://127.0.0.1:9000",
    "model": "base.en",
    "timeout_secs": 30
  },
  "tenants": [
    {
      "id": "hope",
      "display_name": "Hope",
      "route": "/hope",
      "agent_path": "../templates/tenant/agent.md",
      "bootstrap_path": "../templates/tenant/bootstrap.md",
      "memory_path": "../data/hope.sqlite",
      "model": {
        "provider": "github-models",
        "base_url": "https://models.inference.ai.azure.com",
        "model": "gemini-3.0-flash-preview",
        "api_key_env": "GITHUB_TOKEN"
      },
      "proactive": {
        "gentle_checkins_enabled": true,
        "quiet_hours": [
          "22:00-07:00"
        ]
      },
      "gateways": {
        "web": {
          "enabled": true
        },
        "telegram": {
          "enabled": true,
          "token_env": "HOPE_TELEGRAM_TOKEN",
          "binding": "@hope_companion_bot"
        },
        "whatsapp": {
          "enabled": true,
          "token_env": "HOPE_WHATSAPP_TOKEN",
          "binding": "+15555550123"
        }
      }
    }
  ]
}
